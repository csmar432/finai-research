{
  "_schema_version": "2.1",
  "_description": "AI 模型配置 v2.1 — 多模型全备选架构（2026-05-29 实测验证）",
  "_model_ids": {
    "deepseek_flash":          "deepseek-chat",
    "deepseek_pro":            "deepseek-v3",
    "deepseek_r1":             "deepseek-reasoner",
    "gpt_5_4_mini":           "gpt-4o-mini",
    "gpt_5_5_mini":           "gpt-4o-mini",
    "claude_sonnet":           "claude-sonnet-4-20250514",
    "claude_opus":             "claude-3-5-sonnet-20241022",
    "deepseek_v4_pro_relay":   "deepseek-chat",
    "gemini_20_flash":         "gemini-2.0-flash",
    "kimi":                    "moonshot-v1-8k",
    "qwen":                    "qwen-plus",
    "minimax":                 "abab6.5s-chat",
    "glm":                     "glm-4-plus",
    "local_ollama":             "llama3.2"
  },
  "deepseek": {
    "api_key": "$DEEPSEEK_API_KEY",
    "base_url": "https://api.deepseek.com",
    "models": {
      "deepseek-chat": "DeepSeek Chat — V3，1M context，速度快，成本低，中文质量好",
      "deepseek-v3": "DeepSeek V3 — 236B/37B，深度推理，最强编程",
      "deepseek-reasoner": "DeepSeek R1 — 数学/复杂推理专用，超越o3"
    },
    "defaults": {
      "temperature": 0.7,
      "max_tokens": 8192
    }
  },
  "relay": {
    "api_key": "$RELAY_API_KEY",
    "base_url": "https://api.b.ai/v1",
    "description": "Relay 中转 API — B.AI，支持多模型中转（2026-06-04 验证）",
    "models": {
      "gpt-4o-mini": "GPT-4o-Mini — 实测可用，英文写作/翻译/快速任务",
      "deepseek-chat": "DeepSeek-Chat — 实测可用（Relay版）",
      "claude-sonnet-4-20250514": "Claude Sonnet — 实测可用，英文复杂分析/翻译",
      "claude-3-5-sonnet-20241022": "Claude 3.5 Sonnet — 高级推理",
      "gemini-2.0-flash": "Gemini 2.0-Flash — 快速任务/中文",
      "moonshot-v1-8k": "Moonshot (Kimi) — 长文档分析",
      "qwen-plus": "Qwen-Plus — 阿里通义，中文结构化",
      "glm-4-plus": "GLM-4-Plus — 智谱，结构化输出"
    },
    "defaults": {
      "temperature": 0.7,
      "max_tokens": 8192
    }
  },
  "ollama": {
    "provider": "ollama",
    "model_id": "llama3.2",
    "base_url": "http://localhost:11434",
    "temperature_range": [0.0, 2.0],
    "max_tokens": 8192,
    "cost_per_1k_input": 0.0,
    "cost_per_1k_output": 0.0,
    "region": "local",
    "enabled": false
  }
}

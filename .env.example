# =============================================================================
# 论文-研报工作流 · 环境变量配置模板
#
# 使用方法：
#   1. cp .env.example .env.local      ← 创建本地配置（不被git跟踪）
#   2. 填入 Key（把空值替换为真实值）
#   3. 系统自动加载 .env.local（优先级高于 .env）
#
# 交互式引导（推荐首次配置）：
#   python scripts/setup_wizard.py --guided
#   python scripts/setup_wizard.py --status
#
# 配置优先级：.env.local > .env > 默认值
#
# 快速开始：只需要 DEEPSEEK_API_KEY（必填）即可运行全部核心功能。
# 其他 keys 按研究方向选择配置，详见各分组注释。
# =============================================================================

# ── AI 模型（必填 1 项）───────────────────────────────────────────────────────
# DeepSeek 直连（推荐，中文最优，支持 1M context）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# B.AI 中转（可选，用于 GPT/Claude 模型）
RELAY_API_KEY=
RELAY_BASE_URL=https://api.b.ai/v1

# ── 金融数据 API ─────────────────────────────────────────────────────────────
# Tushare Pro — A股数据（需 Token，注册：https://tushare.pro/register）
TUSHARE_TOKEN=

# ── Legal Risk Servers (OPT-IN ONLY) ─────────────────────────────────────────
# 3 MCP servers (cnki, wanfang, chinese-literature) are DISABLED by default.
# They scrape websites that prohibit automated access (legal risk).
# To enable: set CLI_ACCEPT_RISK=cnki,wanfang,chinese-literature
# NEVER commit this with actual values. See LEGAL_CONSENT.md.
CLI_ACCEPT_RISK=

# EODHD — 全球宏观/国债（需 Key，Demo Tier 免费：https://eodhd.com）
EODHD_API_KEY=

# FRED — 美联储经济数据（免费 Token：https://fred.stlouisfed.org）
FRED_API_KEY=

# CSMAR 国泰安（机构账号：https://www.gtadata.com）
CSMAR_API_KEY=

# ── 学术 / 搜索 API ────────────────────────────────────────────────────────────
# Brave Search — 网络搜索（免费额度 5$/月：https://brave.com/search/api/）
BRAVE_SEARCH_API_KEY=

# Semantic Scholar / OpenAlex（免费，部分需要 Key）
SS_API_KEY=
OPENALEX_API_KEY=

# NewsAPI — 财经新闻（免费 Tier：https://newsapi.org）
NEWSAPI_API_KEY=

# ── 其他可选 API ───────────────────────────────────────────────────────────────
ZHIPU_API_KEY=          # 智谱 GLM（可选）
E2B_API_KEY=           # E2B 云端沙箱（可选，https://e2b.dev）
ALPHA_VANTAGE_API_KEY=  # 技术指标/外汇（免费额度 25次/天）
TIINGO_API_KEY=         # 美股基本面（https://api.tiingo.com）
COINGECKO_API_KEY=      # 加密货币（免费）
POLYGON_API_KEY=        # 实时行情
FINANCIAL_DATASETS_API_KEY=  # 美股财务数据

# ── Ollama 本地模型（可选）─────────────────────────────────────────────────────
# 启用：OLLAMA_ENABLED=true 并运行 `ollama serve`
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120
OLLAMA_SANITIZE_DATA=true

# ── 模拟数据控制 ─────────────────────────────────────────────────────────────
# confirm — 调用前需确认（默认，教学/演示）
# allow    — 直接放行，自动化脚本
# disabled — 完全禁用，正式生产环境
MCP_MOCK_MODE=confirm

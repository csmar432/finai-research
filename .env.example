# =============================================================================
# 论文-研报工作流 · 环境变量配置模板
#
# 使用方法：
#   1. cp .env.example .env.local      ← 创建本地配置（不被git跟踪）
#   2. 填入真实 Key（把空值替换为真实 Key）
#   3. 系统自动加载 .env.local 中的值（优先级高于 .env）
#
# 交互式引导配置（推荐）：
#   python scripts/setup_wizard.py --guided
#   python scripts/setup_wizard.py --status
#
# 配置优先级：.env.local > .env > 默认值
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 研究方向配置指南
# ─────────────────────────────────────────────────────────────────────────────
#
# 根据你的研究方向，只需要配置相关项即可：
#
# 【A股研究】（上市公司分析）
#   必须：DEEPSEEK_API_KEY
#   推荐：TUSHARE_TOKEN（行情/财务/资金流）
#   可选：RELAY_API_KEY, BRAVE_SEARCH_API_KEY, OLLAMA_ENABLED
#   MCP：user-tushare, user-eastmoney-reports/fund/bond
#
# 【宏观经济研究】
#   必须：DEEPSEEK_API_KEY
#   推荐：BRAVE_SEARCH_API_KEY, EODHD_API_KEY
#   可选：FRED_API_KEY, user-wb-data, user-imf-data, user-oecd-data
#   MCP：user-financial, user-enhanced-finance, user-macro-stats
#
# 【实证学术论文】
#   必须：DEEPSEEK_API_KEY
#   推荐：TUSHARE_TOKEN, BRAVE_SEARCH_API_KEY
#   可选：OLLAMA_ENABLED, user-wb-data, user-bea-data
#   MCP：user-tushare, user-wb-data, user-financial, user-bea-data
#
# 【量化投资研究】
#   必须：DEEPSEEK_API_KEY, TUSHARE_TOKEN
#   推荐：EODHD_API_KEY, user-enhanced-finance
#   可选：OLLAMA_ENABLED, user-e2b-mcp, user-playwright-mcp
#   MCP：user-tushare, user-eodhd, user-enhanced-finance, user-e2b-mcp
#
# 【金融研究报告撰写】
#   必须：DEEPSEEK_API_KEY
#   推荐：RELAY_API_KEY, TUSHARE_TOKEN, BRAVE_SEARCH_API_KEY
#   可选：OLLAMA_ENABLED
#   MCP：user-tushare, user-eastmoney-reports, user-financial, user-wb-data
#

# ─────────────────────────────────────────────────────────────────────────────
# AI 模型 — 双轨配置说明
# ─────────────────────────────────────────────────────────────────────────────
#
# 系统内置 AI Router（scripts/ai_router.py），支持：
#
#   ① 自动寻优（默认行为）
#      系统自动在多个模型间 failover：
#        - 中文写作/分析 → DeepSeek V4 Flash（直连，速度快，成本低）
#        - 英文写作/翻译 → GPT-4o / Claude 3.5 Sonnet（经 B.AI 中转）
#        - 深度推理     → DeepSeek V4 Pro / Claude 3 Opus
#        - 备选兜底     → Ollama 本地模型（需自行部署）
#      你只需配置 Key，无需关心用哪个模型，系统自动选最快的。
#
#   ② 用户手动指定（可选，覆盖自动寻优）
#      在代码中调用时传入 model 参数，如：
#        router.chat("任务", model="deepseek")   # 强制用 DeepSeek
#        router.chat("任务", model="gpt5")       # 强制用 B.AI GPT
#        router.chat("任务", model="claude-sonnet")  # 强制用 Claude
#      可用模型别名见 scripts/ai_router.py 中的 Task → ModelKey 路由表。
#
#   推荐配置（至少选一个）：
#     DeepSeek 直连（中文）：速度快，成本低
#     B.AI 中转（英文/Claude）：GPT/Claude 模型更擅长英文写作和翻译
#
# ─────────────────────────────────────────────────────────────────────────────

# ── AI 模型 API Keys ────────────────────────────────────────────────────────

# DeepSeek 直连（推荐，中文最优，1M context）
#   模型：deepseek-chat, deepseek-v4-pro, deepseek-reasoner
#   指定方式：model="deepseek" / model="deepseek_pro" / model="deepseek-r1"
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Relay 中转（B.AI — 2026-05-29 实测验证可用模型）
#   ⚠️ 不是所有模型都能用！实测通过的：
#     ✅ gpt-4o / gpt-4o-mini（OpenAI 模型名，需在 relay 后端配置对应模型）
#     ✅ deepseek-v4-flash  ✅ deepseek-v4-pro（DeepSeek 直连或 relay）
#     注：GLM/Kimi 模型名请参考 relay 后端实际部署的模型
#     ❌ gemini 系列（B.AI 返回空内容，暂不支持）
#   指定方式：model="gpt5" / model="claude-sonnet" / model="claude-opus"
RELAY_API_KEY=
RELAY_BASE_URL=https://api.b.ai/v1

# 智谱 GLM（可选，用于结构化输出）
ZHIPU_API_KEY=

# ── 金融数据 API Keys ───────────────────────────────────────────────────────

# Tushare Pro — A股数据（行情/财务/融资融券/北向资金）
# 获取：https://tushare.pro/register（注册即送积分）
# 对应 MCP：user-tushare
TUSHARE_TOKEN=

# ── 图表评估（VLM）─────────────────────────────────────────────────────
#   可选：OPENAI_API_KEY（GPT-4V 图表评估）
#   可选：ANTHROPIC_API_KEY（Claude 图表评估）
# ── 其他数据源 ──────────────────────────────────────────────────────
#   可选：IMF_API_KEY（IMF数据 via akshare，无需额外Key）

# EODHD — 全球宏观数据（GDP/CPI/通胀/失业率/国债收益率/经济日历）
# 获取：https://eodhd.com（免费 Demo Tier 已可用）
# 对应 MCP：user-eodhd
EODHD_API_KEY=

# FRED — 美联储经济数据（可通过 EODHD 获取大部分）
# 获取：https://fred.stlouisfed.org（免费注册）
FRED_API_KEY=

# CSMAR 国泰安（可选，机构数据库，需机构账号）
# 获取：https://www.gtadata.com
# 对应 MCP：user-csmar
CSMAR_API_KEY=

# ── 可选 API Keys（按研究方向选择性配置）───────────────────────────────

# Brave Search — 网络搜索（免费额度 5$/月，超出需充值）
# 获取：https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=

# E2B Cloud Sandbox — 云端代码执行（支持GPU沙箱，用于量化回测）
# 获取：https://e2b.dev（免费注册有额度）
# 对应 MCP：user-e2b-mcp
E2B_API_KEY=

# Alpha Vantage — 技术指标，外汇（免费额度：25次/天）
# 获取：https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# Tiingo — 美股基本面+新闻
# 获取：https://api.tiingo.com/documentation/general/welcome
TIINGO_API_KEY=

# 财经新闻
NEWSAPI_API_KEY=

# 学术论文元数据（免费）
OPENALEX_API_KEY=

# Semantic Scholar — 学术论文搜索（免费额度：100次/5分钟）
# 获取：https://www.semanticscholar.org/product/api（免费注册）
SS_API_KEY=

# 美股财务数据
FINANCIAL_DATASETS_API_KEY=

# 实时行情
POLYGON_API_KEY=

# 加密货币
COINGECKO_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# 模拟数据控制
# ─────────────────────────────────────────────────────────────────────────────
#
# 控制模拟/演示数据服务器的行为：
#   confirm  — （默认）调用前需用户确认，适合教学/演示
#   allow    — 直接放行，无需确认，适合自动化脚本
#   disabled — 完全禁用，返回错误，适合正式生产环境
MCP_MOCK_MODE=confirm

# ─────────────────────────────────────────────────────────────────────────────
# Ollama 本地模型（可选 — 自动云端/本地 Fallback）
# ─────────────────────────────────────────────────────────────────────────────
#
# OLLAMA_ENABLED=true 时，ollama 作为云端模型全挂后的最后兜底。
# 默认不启用（OLLAMA_ENABLED=false），节省本地资源。
#
# 配置步骤：
#   1. 安装 Ollama：brew install ollama
#   2. 拉取模型：ollama pull llama3.2
#   3. 启动服务：ollama serve
#   4. 设置 OLLAMA_ENABLED=true
#
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120
OLLAMA_SANITIZE_DATA=true

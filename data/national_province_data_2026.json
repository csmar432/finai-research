  "acquisition_routes": {
    "description": "数据获取路径定义。MCP优先级：直接API > 间接API > 手动录入。",
    "tier1_mcp": [
      {
        "id": "wb_indicator",
        "server": "user-wb-data",
        "description": "World Bank API — 全球GDP/CPI/人口等宏观指标",
        "params": {
          "country_code": "CHN",
          "indicator": "wb_gdp_usd"
        },
        "covers": [
          "ECON:GDP",
          "ECON:人均GDP"
        ],
        "note": "无需API Key，https://api.worldbank.org/v2/country/CHN/indicator/NY.GDP.MKTP.CD"
      },
      {
        "id": "macro_china",
        "server": "user-financial",
        "description": "akshare中国宏观 — CPI/PPI/GDP/PMI等",
        "params": {
          "indicator": "gdp"
        },
        "covers": [
          "ECON:GDP增速",
          "ECON:CPI",
          "ECON:PPI"
        ],
        "note": "无需API Key，akshare本地缓存"
      }
    ],
    "tier2_api": [
      {
        "id": "brave_search",
        "server": "user-brave-search",
        "description": "Brave Search — 各省公报全文检索",
        "params": {
          "query": "2024年统计公报 GDP R&D"
        },
        "covers": [
          "全指标辅助检索"
        ],
        "note": "需BRAVE_SEARCH_API_KEY，检索各省统计公报页面"
      },
      {
        "id": "fetch_gov",
        "server": "user-fetch",
        "description": "网页抓取 — 各省统计局/科技厅官网",
        "params": {
          "url": "https://tjj.hubei.gov.cn/tjsj/tjgb/"
        },
        "covers": [
          "各省公报全文"
        ],
        "note": "无需API Key，直接抓取政府官网"
      }
    ],
    "tier3_manual": [
      {
        "id": "manual_nbs",
        "description": "国家统计局 — R&D公报、全国科技经费统计",
        "url": "https://www.stats.gov.cn/sj/zxfb/202509/t20250930_194823.html",
        "covers": [
          "RD:R&D经费",
          "RD:R&D强度"
        ],
        "note": "科技部/国家统计局联合发布（每年9月），含分省数据"
      },
      {
        "id": "manual_moe",
        "description": "教育部 — 高等教育统计数据",
        "url": "https://www.moe.gov.cn/s78/A03/moe_560/",
        "covers": [
          "EDU:高校数量",
          "EDU:本专科在校生",
          "EDU:研究生在学"
        ],
        "note": "教育部发展规划司，每年8月发布"
      },
      {
        "id": "manual_most",
        "description": "科技部 — 国家创新能力评价/火炬统计",
        "url": "https://www.most.gov.cn/kjtj/",
        "covers": [
          "ENT:高新技术企业",
          "ENT:科技型中小企业",
          "ENT:专精特新"
        ],
        "note": "火炬中心发布高新技术企业认定名单"
      }
    ],
    "workflow": {
      "step1": {
        "action": "调用 get_all_provinces_summary 查看已收录哪些省",
        "mcp_tool": "get_all_provinces_summary"
      },
      "step2": {
        "action": "对 verification=empty 的省，按 acquisition_routes 填充数据",
        "mcp_tool": "get_province_indicator"
      },
      "step3": {
        "action": "批量获取时间序列",
        "mcp_tool": "get_province_timeseries"
      },
      "step4": {
        "action": "获取全国排名表",
        "mcp_tool": "get_province_rankings"
      },
      "step5": {
        "action": "保存到 national_province_data_2026.json",
        "write_back": true
      },
      "step6": {
        "action": "导出 Excel 报告",
        "export_xlsx": "national_province_data_2026.xlsx"
      }
    }
  },

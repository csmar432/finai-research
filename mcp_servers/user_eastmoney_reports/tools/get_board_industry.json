{
  "name": "get_board_industry",
  "description": "获取行业板块数据（行业列表/行情/历史走势）。使用 akshare 东方财富接口，无需 API Key。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "data_type": {
        "type": "string",
        "enum": [
          "names",
          "spot",
          "hist"
        ]
      },
      "industry_name": {
        "type": "string"
      },
      "start_date": {
        "type": "string"
      },
      "end_date": {
        "type": "string"
      }
    }
  }
}

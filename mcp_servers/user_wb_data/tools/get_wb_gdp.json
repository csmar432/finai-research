{
  "name": "get_wb_gdp",
  "description": "获取World Bank GDP数据。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "country_code": {
        "type": "string",
        "description": "国家代码"
      },
      "indicator": {
        "type": "string",
        "description": "指标: gdp_usd/gdp_growth/gdp_per_capita"
      },
      "per_page": {
        "type": "integer",
        "description": "返回记录数"
      }
    },
    "required": [
      "country_code"
    ]
  }
}

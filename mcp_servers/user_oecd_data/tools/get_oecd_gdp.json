{
  "name": "get_oecd_gdp",
  "description": "获取OECD GDP数据。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "country_code": {
        "type": "string",
        "description": "国家代码"
      },
      "indicator": {
        "type": "string",
        "description": "指标: gdp/gdp_growth/gdp_per_capita"
      },
      "year_range": {
        "type": "string",
        "description": "年份范围"
      }
    },
    "required": [
      "country_code"
    ]
  }
}

{
  "name": "get_imf_ifs",
  "description": "获取IMF国际金融统计(IFS)数据。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "country_code": {
        "type": "string",
        "description": "国家代码"
      },
      "indicator": {
        "type": "string",
        "description": "指标: exchange_rate/reserve/money_supply/interest_rate",
        "default": "exchange_rate"
      }
    },
    "required": [
      "country_code"
    ]
  }
}

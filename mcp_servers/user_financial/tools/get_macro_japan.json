{
  "name": "get_macro_japan",
  "description": "获取日本宏观经济指标。使用 akshare 接口，无需 API Key。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "indicator": {
        "type": "string",
        "description": "指标名称",
        "enum": [
          "cpi",
          "unemployment_rate",
          "bank_rate",
          "head_indicator"
        ]
      }
    },
    "required": [
      "indicator"
    ]
  }
}

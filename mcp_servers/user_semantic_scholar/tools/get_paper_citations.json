{
  "name": "get_paper_citations",
  "description": "获取引用某论文的所有论文（正向引文）。\n\n用于发现后续研究工作，理解论文的学术影响网络。返回高引用的引用者，按引用量排序。",
  "inputSchema": {
    "type": "object",
    "properties": {
      "paper_id": {
        "type": "string",
        "description": "论文标识符（DOI/arXiv ID/S2Id）"
      },
      "limit": {
        "type": "integer",
        "description": "返回引用者数量（默认20，最大100）",
        "default": 20
      },
      "offset": {
        "type": "integer",
        "description": "分页偏移量",
        "default": 0
      },
      "min_citation_count": {
        "type": "integer",
        "description": "只返回引用量>=此值的论文",
        "default": 0
      }
    },
    "required": ["paper_id"]
  }
}
